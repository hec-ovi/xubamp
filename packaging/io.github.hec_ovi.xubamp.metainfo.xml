<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.hec_ovi.xubamp</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0-or-later</project_license>
  <name>xubamp</name>
  <summary>Native Wayland audio player with classic skin support</summary>
  <description>
    <p>
      xubamp is a native Wayland audio player for Ubuntu 26.04. It decodes
      MP3 and WAV files, sends audio to PipeWire, and renders classic Winamp
      skin archives.
    </p>
  </description>
  <developer id="io.github.hec_ovi">
    <name>Hector Oviedo</name>
  </developer>
  <launchable type="desktop-id">xubamp.desktop</launchable>
  <icon type="stock">xubamp</icon>
  <url type="homepage">https://github.com/hec-ovi/xubamp</url>
  <url type="bugtracker">https://github.com/hec-ovi/xubamp/issues</url>
  <provides>
    <binary>xubamp</binary>
    <mediatype>audio/mpeg</mediatype>
    <mediatype>audio/x-wav</mediatype>
    <mediatype>audio/wav</mediatype>
  </provides>
  <categories>
    <category>AudioVideo</category>
    <category>Audio</category>
  </categories>
  <supports>
    <control>pointing</control>
    <control>keyboard</control>
  </supports>
